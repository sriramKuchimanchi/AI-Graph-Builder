# ---- Server ----
PORT=4000
NODE_ENV=development

# ---- PostgreSQL (set up via pgAdmin 4) ----
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=synapse

# ---- File uploads ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# ---- LLM API keys (placeholders — fill in if/when you integrate) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
