# Server
PORT=4000
NODE_ENV=development

# CORS — frontend origin
CORS_ORIGIN=http://localhost:8080

# PostgreSQL (set up via pgAdmin 4)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=synapse

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
RESET_TOKEN_EXPIRES_MIN=30

# LLM API keys (optional — stubs work without them)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
